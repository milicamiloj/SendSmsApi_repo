{
  "openapi": "3.1.1",
  "info": {
    "title": "SendSms API",
    "description": "REST API za slanje SMS poruka preko SDP ParlayX servisa",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:5180"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "SendSmsApi"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/Sms/send": {
      "post": {
        "tags": [
          "Sms"
        ],
        "summary": "Šalje SMS poruku preko SDP ParlayX servisa",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendSmsRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SendSmsRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SendSmsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SendSmsResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendSmsResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendSmsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Sms/send-logo": {
      "post": {
        "tags": [
          "Sms"
        ],
        "summary": "Slanje SMS Logo — nije implementirano",
        "responses": {
          "501": {
            "description": "Not Implemented"
          }
        }
      }
    },
    "/api/Sms/send-ringtone": {
      "post": {
        "tags": [
          "Sms"
        ],
        "summary": "Slanje SMS Ringtone — nije implementirano",
        "responses": {
          "501": {
            "description": "Not Implemented"
          }
        }
      }
    },
    "/api/Sms/delivery-status/{requestIdentifier}": {
      "get": {
        "tags": [
          "Sms"
        ],
        "summary": "Dohvatanje statusa dostave — nije implementirano",
        "parameters": [
          {
            "name": "requestIdentifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "501": {
            "description": "Not Implemented"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SendSmsRequest": {
        "required": [
          "sessionMSISDN",
          "message",
          "shortNumber",
          "userName",
          "password"
        ],
        "type": "object",
        "properties": {
          "sessionMSISDN": {
            "type": "string",
            "description": "Broj telefona primaoca u formatu 381641234567"
          },
          "message": {
            "type": "string",
            "description": "Tekst SMS poruke koja se šalje"
          },
          "shortNumber": {
            "type": "string",
            "description": "Kratki broj pošiljaoca (npr. 12345)"
          },
          "userName": {
            "type": "string",
            "description": "Korisničko ime za autentifikaciju na SDP"
          },
          "password": {
            "type": "string",
            "description": "Lozinka za autentifikaciju na SDP"
          }
        }
      },
      "SendSmsResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "True ako je SMS uspješno poslat"
          },
          "requestId": {
            "type": [
              "null",
              "string"
            ],
            "description": "Identifikator zahteva koji je vratio SDP"
          },
          "errorMessage": {
            "type": [
              "null",
              "string"
            ],
            "description": "Poruka greške ukoliko slanje nije uspjelo"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "SendSmsApi"
    },
    {
      "name": "Sms"
    }
  ]
}